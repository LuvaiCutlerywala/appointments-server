{
  "description": "Create new contact tags",
  "inputSchema": {
    "type": "object",
    "properties": {
      "tags": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "tagName": {
              "type": "string",
              "description": "Name of the tag"
            },
            "signUpKeyword": {
              "type": "string",
              "description": "Sign-up keyword"
            },
            "shortCodeKeyword": {
              "type": "string",
              "description": "Short code keyword"
            },
            "sendConfirmationText": {
              "type": "integer",
              "description": "Whether to send confirmation text (0 or 1)"
            },
            "confirmationText": {
              "type": "string",
              "description": "Confirmation text message"
            },
            "sendFrom": {
              "type": "integer",
              "description": "Phone number ID to send from"
            }
          },
          "required": ["tagName"]
        }
      }
    },
    "required": ["tags"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "statusCode": {
        "type": "string"
      },
      "message": {
        "type": "string"
      }
    }
  }
}
