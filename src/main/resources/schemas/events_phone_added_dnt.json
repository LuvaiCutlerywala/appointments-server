{
  "description": "Get phone number added to DNT events",
  "inputSchema": {
    "type": "object",
    "properties": {
      "limit": {
        "type": "integer",
        "description": "Number of events to retrieve",
        "default": 10
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "events": {
        "type": "array"
      }
    }
  }
}
